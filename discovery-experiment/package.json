{
  "name": "discovery-experiment",
  "version": "1.0.0",
  "description": "Discovery Mode vs Standard Mode LLM experiment",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node --use-system-ca cli.js",
    "chat": "node --use-system-ca cli.js",
    "discovery": "node --use-system-ca cli.js",
    "discover": "node --use-system-ca cli.js",
    "bench": "node --use-system-ca benchmark.js",
    "bench:mini": "node --use-system-ca benchmark.js --file benchmarks/mini_api_cases.json",
    "bench:tech": "node --use-system-ca benchmark.js --file benchmarks/tech_challenge_cases.json",
    "server": "node --use-system-ca server.js",
    "test": "vitest --run"
  },
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "vitest": "^1.2.0",
    "fast-check": "^3.15.0"
  }
}
